{
  "name": "zixi-wallet-frontend",
  "version": "1.0.9",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "scripts": {
    "start": "node apps/api/dist/index.js",
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter @repo/api... build && pnpm --filter web build",
    "build:web": "pnpm --filter @repo/shared build && pnpm --filter web build && (pnpm --filter web build:prerender || echo prerender skipped)",
    "preview": "pnpm --filter web preview"
  },
  "devDependencies": {
    "drizzle-orm": "^0.30.10",
    "esbuild": "^0.27.4",
    "eslint": "^8.57.0",
    "postgres": "^3.4.8",
    "prettier": "^3.2.0",
    "shx": "^0.4.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["puppeteer"]
  },
  "dependencies": {
    "ethers": "^6.16.0"
  }
}
